# Database
DATABASE_URL=postgresql://ritualpad:ritualpad@localhost:5432/ritualpad

# Ritual Chain RPC
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_CHAIN_ID=1979

# Contract Addresses (update after deployment)
FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000

# Server
API_PORT=3001
API_HOST=0.0.0.0

# Security — Set API_KEY to require X-API-Key header on write endpoints (merkle/generate)
