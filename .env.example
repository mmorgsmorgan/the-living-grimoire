# ========================================
# Ritual NFT Mint — Environment Variables
# Copy to .env.local and fill in values
# ========================================

# NFT contract address (deploy your contract and paste address here)
NEXT_PUBLIC_NFT_CONTRACT=0xb26e453CAF6EAa68248447052A0AC75a84650312

# Ritual Chain RPC (default: public endpoint)
NEXT_PUBLIC_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_WS_URL=wss://rpc.ritualfoundation.org/ws

# WalletConnect Project ID (optional — enables WalletConnect support)
# Get one at: https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=
